			<Add library="dxguid" />
			<Add directory="./SDL2/lib" />
		</Linker>
		<ExtraCommands>
			<Add after="XCOPY .\SDL2\bin\*.dll $(TARGET_OUTPUT_DIR) /D /Y" />
		</ExtraCommands>
